const Alert = require('../models/Alert');
const polling = require('../services/pollingLoop');

exports.getAlerts = async (req, res, next) => {
  try {
    const alerts = await Alert.find({ userId: req.user.id }).sort({ createdAt: -1 });
    res.json({ success: true, alerts });
  } catch (error) { next(error); }
};

exports.createAlert = async (req, res, next) => {
  try {
    const { symbol, exchange, condition } = req.body;
    if (!symbol || !exchange || !condition?.type || condition?.value == null) {
      return res.status(400).json({ error: 'symbol, exchange, condition.type and value are required.' });
    }
    const alert = await Alert.create({
      userId: req.user.id,
      symbol: symbol.toUpperCase(),
      exchange: exchange.toUpperCase(),
      condition
    });
    
    // Auto-subscribe symbol to polling so the alert engine receives ticks
    polling.subscribe(`${exchange.toUpperCase()}:${symbol.toUpperCase()}`);

    res.status(201).json({ success: true, alert });
  } catch (error) { next(error); }
};

exports.deleteAlert = async (req, res, next) => {
  try {
    await Alert.findOneAndDelete({ _id: req.params.id, userId: req.user.id });
    res.json({ success: true });
  } catch (error) { next(error); }
};

exports.dismissAlert = async (req, res, next) => {
  try {
    const alert = await Alert.findOneAndUpdate(
      { _id: req.params.id, userId: req.user.id },
      { status: 'dismissed' },
      { new: true }
    );
    res.json({ success: true, alert });
  } catch (error) { next(error); }
};
