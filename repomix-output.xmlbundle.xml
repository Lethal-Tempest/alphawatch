import { useState, useEffect } from 'react';
import { Bell, Plus, Trash2, X } from 'lucide-react';
import api from '../../services/api';

const CONDITION_LABELS = {
  price_above: 'Price >', price_below: 'Price <',
  rsi_above: 'RSI >', rsi_below: 'RSI <',
};

export default function AlertsPanel({ symbol, exchange, socket }) {
  const [alerts, setAlerts]     = useState([]);
  const [toasts, setToasts]     = useState([]);
  const [form, setForm]         = useState({ type: 'price_above', value: '', interval: '5m', note: '' });
  const [showForm, setShowForm] = useState(false);

  const fetchAlerts = async () => {
    try { const { data } = await api.get('/alerts'); setAlerts(data.alerts || []); } catch {}
  };
  useEffect(() => { fetchAlerts(); }, []);

  useEffect(() => {
    if (!socket) return;
    const handler = (payload) => {
      setToasts(prev => [...prev, { ...payload, id: Date.now() }]);
      fetchAlerts();
    };
    socket.on('alert_triggered', handler);
    return () => socket.off('alert_triggered', handler);
  }, [socket]);

  const createAlert = async (e) => {
    e.preventDefault();
    if (!symbol) return alert('Select a stock first.');
    if (!form.value) return;
    try {
      await api.post('/alerts', {
        symbol, exchange,
        condition: { type: form.type, value: parseFloat(form.value), interval: form.interval },
        note: form.note,
      });
      setForm({ type: 'price_above', value: '', interval: '5m', note: '' });
      setShowForm(false);
      fetchAlerts();
    } catch {}
  };

  const deleteAlert = async (id) => {
    try { await api.delete(`/alerts/${id}`); fetchAlerts(); } catch {}
  };

  const dismissToast = (id) => setToasts(prev => prev.filter(t => t.id !== id));
  const isRsiType = form.type.startsWith('rsi');

  const inputCls = "w-full border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-indigo-500";
  const inputStyle = { background: 'var(--bg-base)', borderColor: 'var(--border-muted)', color: 'var(--text-primary)' };

  return (
    <div className="flex flex-col gap-3">
      {/* Toast notifications */}
      <div className="fixed top-20 right-4 z-50 flex flex-col gap-2 pointer-events-none">
        {toasts.map(t => (
          <div key={t.id} className="pointer-events-auto bg-amber-950 border border-amber-700 text-amber-200 rounded-xl px-4 py-3 text-xs shadow-2xl flex items-start gap-3 max-w-xs">
            <Bell size={14} className="mt-0.5 shrink-0" />
            <div className="flex-1">
              <p className="font-black">{t.exchange}:{t.symbol} Alert Triggered</p>
              <p className="text-amber-400 mt-0.5">{CONDITION_LABELS[t.condition.type]} {t.condition.value} · LTP ₹{t.ltp}</p>
              {t.note && <p className="text-amber-500 mt-0.5 italic">{t.note}</p>}
            </div>
            <button onClick={() => dismissToast(t.id)} className="cursor-pointer text-amber-500 hover:text-amber-200"><X size={12} /></button>
          </div>
        ))}
      </div>

      {/* Create alert button */}
      <button onClick={() => setShowForm(v => !v)}
        className="flex items-center gap-2 px-3 py-2 bg-indigo-600/10 border border-indigo-500/20 text-indigo-400 rounded-xl text-xs font-bold hover:bg-indigo-600/20 cursor-pointer transition-colors">
        <Plus size={13} />{showForm ? 'Cancel' : `Set Alert${symbol ? ` on ${symbol}` : ''}`}
      </button>

      {/* Create alert form */}
      {showForm && (
        <form onSubmit={createAlert} className="border rounded-xl p-3 space-y-2"
              style={{ background: 'var(--bg-base)', borderColor: 'var(--border-base)' }}>
          <select value={form.type} onChange={e => setForm(f => ({ ...f, type: e.target.value }))}
            className={inputCls} style={inputStyle}>
            <option value="price_above">Price crosses above</option>
            <option value="price_below">Price crosses below</option>
            <option value="rsi_above">RSI crosses above</option>
            <option value="rsi_below">RSI drops below</option>
          </select>
          <input type="number" required placeholder="Value (e.g. 2500)" value={form.value}
            onChange={e => setForm(f => ({ ...f, value: e.target.value }))}
            className={inputCls} style={inputStyle} />
          {isRsiType && (
            <select value={form.interval} onChange={e => setForm(f => ({ ...f, interval: e.target.value }))}
              className={inputCls} style={inputStyle}>
              {['1m','5m','15m','30m','1h','1d'].map(t => <option key={t}>{t}</option>)}
            </select>
          )}
          <input placeholder="Note (optional)" value={form.note}
            onChange={e => setForm(f => ({ ...f, note: e.target.value }))}
            className={inputCls} style={inputStyle} />
          <button type="submit" className="w-full py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-xs font-bold cursor-pointer">
            Create Alert
          </button>
        </form>
      )}

      {/* Alerts list */}
      <div className="flex flex-col gap-1.5 max-h-64 overflow-y-auto">
        {alerts.length === 0 && (
          <p className="text-[11px] text-center py-4" style={{ color: 'var(--text-faint)' }}>No alerts set.</p>
        )}
        {alerts.map(a => (
          <div key={a._id}
            className={`flex items-start justify-between rounded-xl px-3 py-2 border text-xs ${
              a.status === 'triggered' ? 'bg-amber-950/30 border-amber-800/40' :
              a.status === 'dismissed' ? 'opacity-50' : ''
            }`}
            style={!['triggered','dismissed'].includes(a.status) ? {
              background: 'var(--bg-base)', borderColor: 'var(--border-base)'
            } : {}}>
            <div className="flex-1 min-w-0">
              <p className="font-bold truncate" style={{ color: 'var(--text-primary)' }}>{a.exchange}:{a.symbol}</p>
              <p className="text-[10px]" style={{ color: 'var(--text-secondary)' }}>
                {CONDITION_LABELS[a.condition.type]} {a.condition.value}
                {a.condition.type.startsWith('rsi') && ` (${a.condition.interval})`}
              </p>
              {a.note && <p className="text-[10px] italic truncate" style={{ color: 'var(--text-muted)' }}>{a.note}</p>}
              <span className={`text-[9px] font-black uppercase ${
                a.status === 'triggered' ? 'text-amber-400' :
                a.status === 'active' ? 'text-emerald-400' : 'text-slate-500'
              }`}>
                {a.status}
              </span>
            </div>
            <button onClick={() => deleteAlert(a._id)}
              className="hover:text-rose-400 cursor-pointer ml-2 mt-0.5 transition-colors"
              style={{ color: 'var(--text-faint)' }}>
              <Trash2 size={11} />
            </button>
          </div>
        ))}
      </div>
    </div>
  );
}
</file>

