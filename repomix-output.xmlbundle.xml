// ─────────────────────────────────────────────────────────────────────────────
// backend/models/Alert.js
// BUG FIX: File was missing `const mongoose = require('mongoose')` — would
// crash at startup with "mongoose is not defined".
// ─────────────────────────────────────────────────────────────────────────────
const mongoose = require('mongoose');

/**
 * Alert Condition Types:
 *  price_above          — LTP crosses above `value`
 *  price_below          — LTP drops below `value`
 *  rsi_above            — RSI on `condition.interval` crosses above `value` (e.g. 70)
 *  rsi_below            — RSI on `condition.interval` drops below `value` (e.g. 30)
 *  percent_change_above — Daily % change exceeds +`value`
 *  percent_change_below — Daily % change drops below -`value`
 */
const alertConditionSchema = new mongoose.Schema({
  type: {
    type: String,
    enum: ['price_above', 'price_below', 'rsi_above', 'rsi_below', 'percent_change_above', 'percent_change_below'],
    required: true,
  },
  value: {
    type: Number,
    required: true,
  },
  // Only relevant for RSI-based alert types
  interval: {
    type: String,
    enum: ['1m', '5m', '15m', '30m', '1h', '1d'],
    default: '5m',
  },
}, { _id: false });

const alertSchema = new mongoose.Schema({
  userId: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'User',
    required: true,
    index: true,
  },
  symbol: {
    type: String,
    required: true,
    uppercase: true,
    trim: true,
  },
  exchange: {
    type: String,
    required: true,
    enum: ['NSE', 'BSE'],
    uppercase: true,
  },
  condition: {
    type: alertConditionSchema,
    required: true,
  },
  note: {
    type: String,
    trim: true,
    maxlength: 200,
    default: '',
  },
  status: {
    type: String,
    enum: ['active', 'triggered', 'dismissed', 'expired'],
    default: 'active',
    index: true,
  },
  triggeredAt: {
    type: Date,
    default: null,
  },
  // Optional: set a future Date to auto-expire via MongoDB TTL index
  expiresAt: {
    type: Date,
    default: null,
  },
  // If true, alert re-arms to 'active' after being triggered
  isRepeating: {
    type: Boolean,
    default: false,
  },
  createdAt: {
    type: Date,
    default: Date.now,
  },
});

// MongoDB TTL index: automatically deletes documents when expiresAt is reached
alertSchema.index({ expiresAt: 1 }, { expireAfterSeconds: 0 });

// Compound index for the alert engine hot path: query active alerts by symbol+exchange
alertSchema.index({ symbol: 1, exchange: 1, status: 1 });

/**
 * Instance method: evaluate this alert's condition against a live tick.
 * @param {object} tick        — { ltp, percentChange }
 * @param {number|null} rsiVal — current RSI value for this symbol/interval, or null
 * @returns {boolean}
 */
alertSchema.methods.evaluate = function (tick, rsiVal = null) {
  const { type, value } = this.condition;
  switch (type) {
    case 'price_above':          return tick.ltp >= value;
    case 'price_below':          return tick.ltp <= value;
    case 'percent_change_above': return tick.percentChange >= value;
    case 'percent_change_below': return tick.percentChange <= -value;
    case 'rsi_above':            return rsiVal != null && rsiVal >= value;
    case 'rsi_below':            return rsiVal != null && rsiVal <= value;
    default:                     return false;
  }
};

module.exports = mongoose.model('Alert', alertSchema);
</file>

